
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Extended user information including role and onboarding status.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["customer", "supplier", "contractor", "admin"] },
        "onboarded": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Product": {
      "title": "Product",
      "description": "A construction material product in the marketplace.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string" },
        "supplierId": { "type": "string" },
        "supplierName": { "type": "string" },
        "imageUrl": { "type": "string" },
        "rating": { "type": "number" },
        "deliveryEstimate": { "type": "string" },
        "stock": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price", "category", "supplierId"]
    }
  },
  "auth": {
    "providers": ["password", "google.com"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "#/entities/UserProfile",
      "description": "User profiles stored by their authentication UID."
    },
    "/products/{productId}": {
      "schema": "#/entities/Product",
      "description": "Collection of products available in the marketplace."
    }
  }
}
