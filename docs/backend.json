{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Extended user information including role and onboarding status.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["customer", "supplier", "contractor", "admin"] },
        "onboarded": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Product": {
      "title": "Product",
      "description": "A construction material product in the marketplace.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "longDescription": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string" },
        "supplierId": { "type": "string" },
        "supplierName": { "type": "string" },
        "supplierLocation": { "type": "string" },
        "deliveryScore": { "type": "number" },
        "imageUrl": { "type": "string" },
        "images": { "type": "array", "items": { "type": "string" } },
        "rating": { "type": "number" },
        "reviewsCount": { "type": "number" },
        "deliveryEstimate": { "type": "string" },
        "stock": { "type": "number" },
        "specifications": { "type": "object", "additionalProperties": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price", "category", "supplierId"]
    },
    "RFQ": {
      "title": "Request for Quotation",
      "description": "A formal request from a customer to suppliers for pricing and terms.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "customerId": { "type": "string" },
        "customerName": { "type": "string" },
        "projectName": { "type": "string" },
        "projectType": { "type": "string" },
        "location": { "type": "string" },
        "budget": { "type": "number" },
        "timeline": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["open", "closed", "completed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["customerId", "projectName", "projectType", "location", "status"]
    },
    "Quotation": {
      "title": "Quotation",
      "description": "A supplier's response to an RFQ.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "rfqId": { "type": "string" },
        "supplierId": { "type": "string" },
        "supplierName": { "type": "string" },
        "price": { "type": "number" },
        "deliveryTime": { "type": "string" },
        "notes": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "accepted", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["rfqId", "supplierId", "price", "deliveryTime", "status"]
    }
  },
  "auth": {
    "providers": ["password", "google.com"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "#/entities/UserProfile",
      "description": "User profiles stored by their authentication UID."
    },
    "/products/{productId}": {
      "schema": "#/entities/Product",
      "description": "Collection of products available in the marketplace."
    },
    "/rfqs/{rfqId}": {
      "schema": "#/entities/RFQ",
      "description": "Collection of project RFQs."
    },
    "/rfqs/{rfqId}/quotations/{quotationId}": {
      "schema": "#/entities/Quotation",
      "description": "Quotations submitted by suppliers for a specific RFQ."
    }
  }
}